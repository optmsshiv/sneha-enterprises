# SNEHA ENTERPRISES — API .htaccess
# This routes /api/anything to index.php?route=anything
# If this doesn't work on your server, use ?route= directly (already done in JS)

Options -Indexes
RewriteEngine On

# Allow direct PHP file access
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route everything else through index.php
RewriteRule ^(.+)$ index.php?route=$1 [L,QSA]
