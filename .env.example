# ============================================================
#  SNEHA ENTERPRISES — Environment Variables
#  Copy this to .env and fill in your values
#  Then run: source .env && python3 backend/server.py
# ============================================================

# Server
SECRET_KEY=sneha-change-this-secret-key-in-production
JWT_SECRET=sneha-jwt-change-this-in-production

# Email (Gmail recommended — use App Password, not account password)
# Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password

# Admin notification email
ADMIN_EMAIL=admin@snehaenterprises.in
